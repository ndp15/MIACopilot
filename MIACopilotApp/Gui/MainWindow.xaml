<Window x:Class="MIACopilotApp.Gui.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="MIA Copilot — Lernenden-Verwaltung"
        Height="720" Width="1100"
        MinHeight="560" MinWidth="860"
        WindowStartupLocation="CenterScreen"
        FontFamily="Segoe UI"
        Background="#F0F4F8">

    <Window.Resources>
        <!-- NAV BUTTON STYLE -->
        <Style x:Key="NavBtn" TargetType="RadioButton">
            <Setter Property="GroupName" Value="Nav"/>
            <Setter Property="Focusable" Value="False"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="RadioButton">
                        <Border x:Name="Bd" Background="Transparent" Cursor="Hand">
                            <Border x:Name="Inner" Padding="18,13"
                                    BorderThickness="3,0,0,0" BorderBrush="Transparent">
                                <StackPanel Orientation="Horizontal">
                                    <TextBlock x:Name="TbIcon" Text="{TemplateBinding Tag}"
                                               FontSize="15" Width="26" VerticalAlignment="Center"
                                               Foreground="#607799"/>
                                    <TextBlock x:Name="TbLabel" Text="{TemplateBinding Content}"
                                               FontSize="13" Margin="8,0,0,0"
                                               VerticalAlignment="Center" Foreground="#607799"/>
                                </StackPanel>
                            </Border>
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsChecked" Value="True">
                                <Setter TargetName="Bd"    Property="Background"   Value="#243B68"/>
                                <Setter TargetName="Inner" Property="BorderBrush"  Value="#3D7EFF"/>
                                <Setter TargetName="TbIcon"  Property="Foreground" Value="White"/>
                                <Setter TargetName="TbLabel" Property="Foreground" Value="White"/>
                            </Trigger>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter TargetName="Bd" Property="Background" Value="#1F3255"/>
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <!-- PRIMARY BUTTON -->
        <Style x:Key="BtnPrimary" TargetType="Button">
            <Setter Property="Background"   Value="#3D7EFF"/>
            <Setter Property="Foreground"   Value="White"/>
            <Setter Property="Padding"      Value="18,8"/>
            <Setter Property="BorderThickness" Value="0"/>
            <Setter Property="FontSize"     Value="13"/>
            <Setter Property="Cursor"       Value="Hand"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <Border x:Name="Bd" Background="{TemplateBinding Background}"
                                CornerRadius="6" Padding="{TemplateBinding Padding}">
                            <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"/>
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter TargetName="Bd" Property="Background" Value="#2B6EEF"/>
                            </Trigger>
                            <Trigger Property="IsEnabled" Value="False">
                                <Setter TargetName="Bd" Property="Background" Value="#B0C4DE"/>
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <!-- SECONDARY BUTTON -->
        <Style x:Key="BtnSecondary" TargetType="Button">
            <Setter Property="Background"   Value="#EDF2F7"/>
            <Setter Property="Foreground"   Value="#2D3748"/>
            <Setter Property="Padding"      Value="18,8"/>
            <Setter Property="BorderThickness" Value="0"/>
            <Setter Property="FontSize"     Value="13"/>
            <Setter Property="Cursor"       Value="Hand"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <Border x:Name="Bd" Background="{TemplateBinding Background}"
                                CornerRadius="6" Padding="{TemplateBinding Padding}">
                            <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"/>
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter TargetName="Bd" Property="Background" Value="#CBD5E0"/>
                            </Trigger>
                            <Trigger Property="IsEnabled" Value="False">
                                <Setter Property="Foreground" Value="#A0AEC0"/>
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <!-- DANGER BUTTON -->
        <Style x:Key="BtnDanger" TargetType="Button">
            <Setter Property="Background"   Value="#E5534B"/>
            <Setter Property="Foreground"   Value="White"/>
            <Setter Property="Padding"      Value="18,8"/>
            <Setter Property="BorderThickness" Value="0"/>
            <Setter Property="FontSize"     Value="13"/>
            <Setter Property="Cursor"       Value="Hand"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <Border x:Name="Bd" Background="{TemplateBinding Background}"
                                CornerRadius="6" Padding="{TemplateBinding Padding}">
                            <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"/>
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter TargetName="Bd" Property="Background" Value="#C53F38"/>
                            </Trigger>
                            <Trigger Property="IsEnabled" Value="False">
                                <Setter TargetName="Bd" Property="Background" Value="#F5A5A2"/>
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <!-- DATAGRID COLUMN HEADER -->
        <Style TargetType="DataGridColumnHeader">
            <Setter Property="Background"   Value="#F7FAFC"/>
            <Setter Property="Foreground"   Value="#4A5568"/>
            <Setter Property="FontWeight"   Value="SemiBold"/>
            <Setter Property="FontSize"     Value="12"/>
            <Setter Property="Padding"      Value="12,10"/>
            <Setter Property="BorderBrush"  Value="#E2E8F0"/>
            <Setter Property="BorderThickness" Value="0,0,1,1"/>
            <Setter Property="SeparatorBrush" Value="#E2E8F0"/>
        </Style>

        <!-- DATAGRID ROW -->
        <Style TargetType="DataGridRow">
            <Setter Property="Background" Value="White"/>
            <Style.Triggers>
                <Trigger Property="IsSelected" Value="True">
                    <Setter Property="Background" Value="#DBEAFE"/>
                    <Setter Property="Foreground" Value="#1A2B4A"/>
                </Trigger>
                <MultiTrigger>
                    <MultiTrigger.Conditions>
                        <Condition Property="IsMouseOver" Value="True"/>
                        <Condition Property="IsSelected"  Value="False"/>
                    </MultiTrigger.Conditions>
                    <Setter Property="Background" Value="#F0F7FF"/>
                </MultiTrigger>
            </Style.Triggers>
        </Style>

        <!-- DATAGRID CELL -->
        <Style TargetType="DataGridCell">
            <Setter Property="BorderThickness" Value="0"/>
            <Setter Property="Padding" Value="0"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="DataGridCell">
                        <Border Background="{TemplateBinding Background}" Padding="12,0">
                            <ContentPresenter VerticalAlignment="Center"/>
                        </Border>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
            <Style.Triggers>
                <Trigger Property="IsSelected" Value="True">
                    <Setter Property="Background" Value="Transparent"/>
                    <Setter Property="Foreground" Value="#1A2B4A"/>
                    <Setter Property="BorderBrush" Value="Transparent"/>
                </Trigger>
            </Style.Triggers>
        </Style>
    </Window.Resources>

    <Grid>
        <Grid.ColumnDefinitions>
            <ColumnDefinition Width="220"/>
            <ColumnDefinition Width="*"/>
        </Grid.ColumnDefinitions>

        <!-- ============ SIDEBAR ============ -->
        <Border Grid.Column="0" Background="#1A2B4A">
            <DockPanel>
                <!-- Logo -->
                <Border DockPanel.Dock="Top" Padding="20,22,20,18"
                        BorderBrush="#2A3F6A" BorderThickness="0,0,0,1">
                    <StackPanel>
                        <TextBlock Text="MIA Copilot" FontSize="19" FontWeight="Bold" Foreground="White"/>
                        <TextBlock Text="Lernenden-Verwaltung" FontSize="11" Foreground="#607799" Margin="0,3,0,0"/>
                    </StackPanel>
                </Border>

                <!-- Nav Buttons -->
                <StackPanel DockPanel.Dock="Top" Margin="0,10,0,0">
                    <RadioButton x:Name="NavApprentices" Content="Lernende"      Tag="👤" Style="{StaticResource NavBtn}" IsChecked="True" Checked="NavApprentices_Checked"/>
                    <RadioButton x:Name="NavCompanies"   Content="Firmen"        Tag="🏢" Style="{StaticResource NavBtn}" Checked="NavCompanies_Checked"/>
                    <RadioButton x:Name="NavTrainers"    Content="Berufsbildner" Tag="🎓" Style="{StaticResource NavBtn}" Checked="NavTrainers_Checked"/>
                    <RadioButton x:Name="NavJournals"    Content="Arbeitsjournale" Tag="📓" Style="{StaticResource NavBtn}" Checked="NavJournals_Checked"/>
                    <RadioButton x:Name="NavGrades"      Content="Noten"           Tag="★"  Style="{StaticResource NavBtn}" Checked="NavGrades_Checked"/>
                </StackPanel>

                <!-- Footer -->
                <Border DockPanel.Dock="Bottom" Padding="18,12"
                        BorderBrush="#2A3F6A" BorderThickness="0,1,0,0">
                    <TextBlock Text="Daten: app_data.json" FontSize="10" Foreground="#3D5579"/>
                </Border>
            </DockPanel>
        </Border>

        <!-- ============ CONTENT AREA ============ -->
        <Grid Grid.Column="1" Background="#F0F4F8">

            <!-- ===== LERNENDE PANEL ===== -->
            <Grid x:Name="PanelApprentices">
                <Grid.RowDefinitions>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="*"/>
                    <RowDefinition Height="Auto"/>
                </Grid.RowDefinitions>

                <Border Grid.Row="0" Background="White" Padding="24,16"
                        BorderBrush="#E2E8F0" BorderThickness="0,0,0,1">
                    <Grid>
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="*"/>
                            <ColumnDefinition Width="Auto"/>
                        </Grid.ColumnDefinitions>
                        <StackPanel Grid.Column="0">
                            <TextBlock Text="Lernende" FontSize="20" FontWeight="Bold" Foreground="#1A2B4A"/>
                            <TextBlock x:Name="TxtApprenticeCount" FontSize="12" Foreground="#6B7A9B" Margin="0,2,0,0"/>
                        </StackPanel>
                        <Grid Grid.Column="1" VerticalAlignment="Center">
                            <TextBox x:Name="TbApprenticeSearch" Width="240" Height="36"
                                     Padding="12,8" FontSize="13" BorderBrush="#CBD5E0"
                                     TextChanged="TbApprenticeSearch_TextChanged"/>
                            <TextBlock Text="Suchen..." Foreground="#A0AEC0" Margin="14,0"
                                       VerticalAlignment="Center" IsHitTestVisible="False" FontSize="13">
                                <TextBlock.Style>
                                    <Style TargetType="TextBlock">
                                        <Setter Property="Visibility" Value="Collapsed"/>
                                        <Style.Triggers>
                                            <DataTrigger Binding="{Binding Text, ElementName=TbApprenticeSearch}" Value="">
                                                <Setter Property="Visibility" Value="Visible"/>
                                            </DataTrigger>
                                        </Style.Triggers>
                                    </Style>
                                </TextBlock.Style>
                            </TextBlock>
                        </Grid>
                    </Grid>
                </Border>

                <Border Grid.Row="1" Margin="16,12" Background="White" CornerRadius="8"
                        BorderBrush="#E2E8F0" BorderThickness="1">
                    <DataGrid x:Name="GridApprentices"
                              AutoGenerateColumns="False" CanUserAddRows="False" CanUserDeleteRows="False"
                              SelectionMode="Single" SelectionUnit="FullRow"
                              GridLinesVisibility="Horizontal" HorizontalGridLinesBrush="#F1F5F9"
                              Background="White" BorderThickness="0" RowHeight="42" FontSize="13"
                              AlternatingRowBackground="#FAFCFF" HeadersVisibility="Column"
                              SelectionChanged="GridApprentices_SelectionChanged">
                        <DataGrid.Columns>
                            <DataGridTextColumn Header="ID"           Binding="{Binding Id}"          Width="60"  IsReadOnly="True"/>
                            <DataGridTextColumn Header="Vorname"      Binding="{Binding FirstName}"    Width="140" IsReadOnly="True"/>
                            <DataGridTextColumn Header="Nachname"     Binding="{Binding LastName}"     Width="140" IsReadOnly="True"/>
                            <DataGridTextColumn Header="Firma"        Binding="{Binding CompanyName}"  Width="*"   IsReadOnly="True"/>
                            <DataGridTextColumn Header="Berufsbildner" Binding="{Binding TrainerName}" Width="*"   IsReadOnly="True"/>
                        </DataGrid.Columns>
                    </DataGrid>
                </Border>

                <Border Grid.Row="2" Background="White" Padding="16,10"
                        BorderBrush="#E2E8F0" BorderThickness="0,1,0,0">
                    <StackPanel Orientation="Horizontal" HorizontalAlignment="Right">
                        <Button Content="+ Hinzufügen"  Style="{StaticResource BtnPrimary}"   Click="BtnAddApprentice_Click"    Margin="0,0,8,0"/>
                        <Button x:Name="BtnEditApprentice"   Content="Bearbeiten" Style="{StaticResource BtnSecondary}" IsEnabled="False" Click="BtnEditApprentice_Click"   Margin="0,0,8,0"/>
                        <Button x:Name="BtnDeleteApprentice" Content="Löschen"   Style="{StaticResource BtnDanger}"    IsEnabled="False" Click="BtnDeleteApprentice_Click"/>
                    </StackPanel>
                </Border>
            </Grid>

            <!-- ===== FIRMEN PANEL ===== -->
            <Grid x:Name="PanelCompanies" Visibility="Collapsed">
                <Grid.RowDefinitions>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="*"/>
                    <RowDefinition Height="Auto"/>
                </Grid.RowDefinitions>

                <Border Grid.Row="0" Background="White" Padding="24,16"
                        BorderBrush="#E2E8F0" BorderThickness="0,0,0,1">
                    <Grid>
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="*"/>
                            <ColumnDefinition Width="Auto"/>
                        </Grid.ColumnDefinitions>
                        <StackPanel Grid.Column="0">
                            <TextBlock Text="Firmen" FontSize="20" FontWeight="Bold" Foreground="#1A2B4A"/>
                            <TextBlock x:Name="TxtCompanyCount" FontSize="12" Foreground="#6B7A9B" Margin="0,2,0,0"/>
                        </StackPanel>
                        <Grid Grid.Column="1" VerticalAlignment="Center">
                            <TextBox x:Name="TbCompanySearch" Width="240" Height="36"
                                     Padding="12,8" FontSize="13" BorderBrush="#CBD5E0"
                                     TextChanged="TbCompanySearch_TextChanged"/>
                            <TextBlock Text="Suchen..." Foreground="#A0AEC0" Margin="14,0"
                                       VerticalAlignment="Center" IsHitTestVisible="False" FontSize="13">
                                <TextBlock.Style>
                                    <Style TargetType="TextBlock">
                                        <Setter Property="Visibility" Value="Collapsed"/>
                                        <Style.Triggers>
                                            <DataTrigger Binding="{Binding Text, ElementName=TbCompanySearch}" Value="">
                                                <Setter Property="Visibility" Value="Visible"/>
                                            </DataTrigger>
                                        </Style.Triggers>
                                    </Style>
                                </TextBlock.Style>
                            </TextBlock>
                        </Grid>
                    </Grid>
                </Border>

                <Border Grid.Row="1" Margin="16,12" Background="White" CornerRadius="8"
                        BorderBrush="#E2E8F0" BorderThickness="1">
                    <DataGrid x:Name="GridCompanies"
                              AutoGenerateColumns="False" CanUserAddRows="False" CanUserDeleteRows="False"
                              SelectionMode="Single" SelectionUnit="FullRow"
                              GridLinesVisibility="Horizontal" HorizontalGridLinesBrush="#F1F5F9"
                              Background="White" BorderThickness="0" RowHeight="42" FontSize="13"
                              AlternatingRowBackground="#FAFCFF" HeadersVisibility="Column"
                              SelectionChanged="GridCompanies_SelectionChanged">
                        <DataGrid.Columns>
                            <DataGridTextColumn Header="ID"      Binding="{Binding Id}"      Width="60" IsReadOnly="True"/>
                            <DataGridTextColumn Header="Name"    Binding="{Binding Name}"    Width="*"  IsReadOnly="True"/>
                            <DataGridTextColumn Header="Adresse" Binding="{Binding Address}" Width="*"  IsReadOnly="True"/>
                        </DataGrid.Columns>
                    </DataGrid>
                </Border>

                <Border Grid.Row="2" Background="White" Padding="16,10"
                        BorderBrush="#E2E8F0" BorderThickness="0,1,0,0">
                    <StackPanel Orientation="Horizontal" HorizontalAlignment="Right">
                        <Button Content="+ Hinzufügen" Style="{StaticResource BtnPrimary}"   Click="BtnAddCompany_Click"    Margin="0,0,8,0"/>
                        <Button x:Name="BtnEditCompany"   Content="Bearbeiten" Style="{StaticResource BtnSecondary}" IsEnabled="False" Click="BtnEditCompany_Click"   Margin="0,0,8,0"/>
                        <Button x:Name="BtnDeleteCompany" Content="Löschen"   Style="{StaticResource BtnDanger}"    IsEnabled="False" Click="BtnDeleteCompany_Click"/>
                    </StackPanel>
                </Border>
            </Grid>

            <!-- ===== BERUFSBILDNER PANEL ===== -->
            <Grid x:Name="PanelTrainers" Visibility="Collapsed">
                <Grid.RowDefinitions>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="*"/>
                    <RowDefinition Height="Auto"/>
                </Grid.RowDefinitions>

                <Border Grid.Row="0" Background="White" Padding="24,16"
                        BorderBrush="#E2E8F0" BorderThickness="0,0,0,1">
                    <Grid>
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="*"/>
                            <ColumnDefinition Width="Auto"/>
                        </Grid.ColumnDefinitions>
                        <StackPanel Grid.Column="0">
                            <TextBlock Text="Berufsbildner" FontSize="20" FontWeight="Bold" Foreground="#1A2B4A"/>
                            <TextBlock x:Name="TxtTrainerCount" FontSize="12" Foreground="#6B7A9B" Margin="0,2,0,0"/>
                        </StackPanel>
                        <Grid Grid.Column="1" VerticalAlignment="Center">
                            <TextBox x:Name="TbTrainerSearch" Width="240" Height="36"
                                     Padding="12,8" FontSize="13" BorderBrush="#CBD5E0"
                                     TextChanged="TbTrainerSearch_TextChanged"/>
                            <TextBlock Text="Suchen..." Foreground="#A0AEC0" Margin="14,0"
                                       VerticalAlignment="Center" IsHitTestVisible="False" FontSize="13">
                                <TextBlock.Style>
                                    <Style TargetType="TextBlock">
                                        <Setter Property="Visibility" Value="Collapsed"/>
                                        <Style.Triggers>
                                            <DataTrigger Binding="{Binding Text, ElementName=TbTrainerSearch}" Value="">
                                                <Setter Property="Visibility" Value="Visible"/>
                                            </DataTrigger>
                                        </Style.Triggers>
                                    </Style>
                                </TextBlock.Style>
                            </TextBlock>
                        </Grid>
                    </Grid>
                </Border>

                <Border Grid.Row="1" Margin="16,12" Background="White" CornerRadius="8"
                        BorderBrush="#E2E8F0" BorderThickness="1">
                    <DataGrid x:Name="GridTrainers"
                              AutoGenerateColumns="False" CanUserAddRows="False" CanUserDeleteRows="False"
                              SelectionMode="Single" SelectionUnit="FullRow"
                              GridLinesVisibility="Horizontal" HorizontalGridLinesBrush="#F1F5F9"
                              Background="White" BorderThickness="0" RowHeight="42" FontSize="13"
                              AlternatingRowBackground="#FAFCFF" HeadersVisibility="Column"
                              SelectionChanged="GridTrainers_SelectionChanged">
                        <DataGrid.Columns>
                            <DataGridTextColumn Header="ID"       Binding="{Binding Id}"          Width="60"  IsReadOnly="True"/>
                            <DataGridTextColumn Header="Vorname"  Binding="{Binding FirstName}"    Width="160" IsReadOnly="True"/>
                            <DataGridTextColumn Header="Nachname" Binding="{Binding LastName}"     Width="160" IsReadOnly="True"/>
                            <DataGridTextColumn Header="Firma"    Binding="{Binding CompanyName}"  Width="*"   IsReadOnly="True"/>
                        </DataGrid.Columns>
                    </DataGrid>
                </Border>

                <Border Grid.Row="2" Background="White" Padding="16,10"
                        BorderBrush="#E2E8F0" BorderThickness="0,1,0,0">
                    <StackPanel Orientation="Horizontal" HorizontalAlignment="Right">
                        <Button Content="+ Hinzufügen" Style="{StaticResource BtnPrimary}"   Click="BtnAddTrainer_Click"    Margin="0,0,8,0"/>
                        <Button x:Name="BtnEditTrainer"   Content="Bearbeiten" Style="{StaticResource BtnSecondary}" IsEnabled="False" Click="BtnEditTrainer_Click"   Margin="0,0,8,0"/>
                        <Button x:Name="BtnDeleteTrainer" Content="Löschen"   Style="{StaticResource BtnDanger}"    IsEnabled="False" Click="BtnDeleteTrainer_Click"/>
                    </StackPanel>
                </Border>
            </Grid>

            <!-- ===== ARBEITSJOURNALE PANEL ===== -->
            <Grid x:Name="PanelJournals" Visibility="Collapsed">
                <Grid.RowDefinitions>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="*"/>
                    <RowDefinition Height="Auto"/>
                </Grid.RowDefinitions>

                <Border Grid.Row="0" Background="White" Padding="24,16"
                        BorderBrush="#E2E8F0" BorderThickness="0,0,0,1">
                    <Grid>
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="*"/>
                            <ColumnDefinition Width="Auto"/>
                        </Grid.ColumnDefinitions>
                        <StackPanel Grid.Column="0">
                            <TextBlock Text="Arbeitsjournale" FontSize="20" FontWeight="Bold" Foreground="#1A2B4A"/>
                            <TextBlock x:Name="TxtJournalCount" FontSize="12" Foreground="#6B7A9B" Margin="0,2,0,0"/>
                        </StackPanel>
                        <Grid Grid.Column="1" VerticalAlignment="Center">
                            <TextBox x:Name="TbJournalSearch" Width="240" Height="36"
                                     Padding="12,8" FontSize="13" BorderBrush="#CBD5E0"
                                     TextChanged="TbJournalSearch_TextChanged"/>
                            <TextBlock Text="Suchen..." Foreground="#A0AEC0" Margin="14,0"
                                       VerticalAlignment="Center" IsHitTestVisible="False" FontSize="13">
                                <TextBlock.Style>
                                    <Style TargetType="TextBlock">
                                        <Setter Property="Visibility" Value="Collapsed"/>
                                        <Style.Triggers>
                                            <DataTrigger Binding="{Binding Text, ElementName=TbJournalSearch}" Value="">
                                                <Setter Property="Visibility" Value="Visible"/>
                                            </DataTrigger>
                                        </Style.Triggers>
                                    </Style>
                                </TextBlock.Style>
                            </TextBlock>
                        </Grid>
                    </Grid>
                </Border>

                <Border Grid.Row="1" Margin="16,12" Background="White" CornerRadius="8"
                        BorderBrush="#E2E8F0" BorderThickness="1">
                    <DataGrid x:Name="GridJournals"
                              AutoGenerateColumns="False" CanUserAddRows="False" CanUserDeleteRows="False"
                              SelectionMode="Single" SelectionUnit="FullRow"
                              GridLinesVisibility="Horizontal" HorizontalGridLinesBrush="#F1F5F9"
                              Background="White" BorderThickness="0" RowHeight="42" FontSize="13"
                              AlternatingRowBackground="#FAFCFF" HeadersVisibility="Column"
                              SelectionChanged="GridJournals_SelectionChanged">
                        <DataGrid.Columns>
                            <DataGridTextColumn Header="ID"         Binding="{Binding Id}"             Width="60"  IsReadOnly="True"/>
                            <DataGridTextColumn Header="Titel"      Binding="{Binding Title}"           Width="180" IsReadOnly="True"/>
                            <DataGridTextColumn Header="Datum"      Binding="{Binding DateEntry, StringFormat=dd.MM.yyyy}" Width="100" IsReadOnly="True"/>
                            <DataGridTextColumn Header="Lernender"  Binding="{Binding ApprenticeName}" Width="180" IsReadOnly="True"/>
                            <DataGridTextColumn Header="Inhalt"     Binding="{Binding ContentPreview}" Width="*"   IsReadOnly="True"/>
                        </DataGrid.Columns>
                    </DataGrid>
                </Border>

                <Border Grid.Row="2" Background="White" Padding="16,10"
                        BorderBrush="#E2E8F0" BorderThickness="0,1,0,0">
                    <StackPanel Orientation="Horizontal" HorizontalAlignment="Right">
                        <Button Content="+ Hinzufügen" Style="{StaticResource BtnPrimary}"   Click="BtnAddJournal_Click"    Margin="0,0,8,0"/>
                        <Button x:Name="BtnEditJournal"   Content="Bearbeiten" Style="{StaticResource BtnSecondary}" IsEnabled="False" Click="BtnEditJournal_Click"   Margin="0,0,8,0"/>
                        <Button x:Name="BtnDeleteJournal" Content="Löschen"   Style="{StaticResource BtnDanger}"    IsEnabled="False" Click="BtnDeleteJournal_Click"/>
                    </StackPanel>
                </Border>
            </Grid>

            <!-- ===== NOTEN PANEL ===== -->
            <Grid x:Name="PanelGrades" Visibility="Collapsed">
                <Grid.RowDefinitions>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="*"/>
                    <RowDefinition Height="Auto"/>
                </Grid.RowDefinitions>

                <Border Grid.Row="0" Background="White" Padding="24,16"
                        BorderBrush="#E2E8F0" BorderThickness="0,0,0,1">
                    <Grid>
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="*"/>
                            <ColumnDefinition Width="Auto"/>
                        </Grid.ColumnDefinitions>
                        <StackPanel Grid.Column="0">
                            <TextBlock Text="Noten" FontSize="20" FontWeight="Bold" Foreground="#1A2B4A"/>
                            <TextBlock x:Name="TxtGradeCount" FontSize="12" Foreground="#6B7A9B" Margin="0,2,0,0"/>
                        </StackPanel>
                        <Grid Grid.Column="1" VerticalAlignment="Center">
                            <TextBox x:Name="TbGradeSearch" Width="240" Height="36"
                                     Padding="12,8" FontSize="13" BorderBrush="#CBD5E0"
                                     TextChanged="TbGradeSearch_TextChanged"/>
                            <TextBlock Text="Suchen..." Foreground="#A0AEC0" Margin="14,0"
                                       VerticalAlignment="Center" IsHitTestVisible="False" FontSize="13">
                                <TextBlock.Style>
                                    <Style TargetType="TextBlock">
                                        <Setter Property="Visibility" Value="Collapsed"/>
                                        <Style.Triggers>
                                            <DataTrigger Binding="{Binding Text, ElementName=TbGradeSearch}" Value="">
                                                <Setter Property="Visibility" Value="Visible"/>
                                            </DataTrigger>
                                        </Style.Triggers>
                                    </Style>
                                </TextBlock.Style>
                            </TextBlock>
                        </Grid>
                    </Grid>
                </Border>

                <Border Grid.Row="1" Margin="16,12" Background="White" CornerRadius="8"
                        BorderBrush="#E2E8F0" BorderThickness="1">
                    <DataGrid x:Name="GridGrades"
                              AutoGenerateColumns="False" CanUserAddRows="False" CanUserDeleteRows="False"
                              SelectionMode="Single" SelectionUnit="FullRow"
                              GridLinesVisibility="Horizontal" HorizontalGridLinesBrush="#F1F5F9"
                              Background="White" BorderThickness="0" RowHeight="42" FontSize="13"
                              AlternatingRowBackground="#FAFCFF" HeadersVisibility="Column"
                              SelectionChanged="GridGrades_SelectionChanged">
                        <DataGrid.Columns>
                            <DataGridTextColumn Header="ID"          Binding="{Binding Id}"             Width="60"  IsReadOnly="True"/>
                            <DataGridTextColumn Header="Fach"        Binding="{Binding Subject}"         Width="160" IsReadOnly="True"/>
                            <DataGridTextColumn Header="Note"        Binding="{Binding ValueDisplay}"    Width="80"  IsReadOnly="True"/>
                            <DataGridTextColumn Header="Lernender"   Binding="{Binding ApprenticeName}"  Width="180" IsReadOnly="True"/>
                            <DataGridTextColumn Header="Datum"       Binding="{Binding Date, StringFormat=dd.MM.yyyy}" Width="100" IsReadOnly="True"/>
                            <DataGridTextColumn Header="Bemerkungen" Binding="{Binding Remarks}"         Width="*"   IsReadOnly="True"/>
                        </DataGrid.Columns>
                    </DataGrid>
                </Border>

                <Border Grid.Row="2" Background="White" Padding="16,10"
                        BorderBrush="#E2E8F0" BorderThickness="0,1,0,0">
                    <StackPanel Orientation="Horizontal" HorizontalAlignment="Right">
                        <Button Content="+ Hinzufügen" Style="{StaticResource BtnPrimary}"   Click="BtnAddGrade_Click"    Margin="0,0,8,0"/>
                        <Button x:Name="BtnEditGrade"   Content="Bearbeiten" Style="{StaticResource BtnSecondary}" IsEnabled="False" Click="BtnEditGrade_Click"   Margin="0,0,8,0"/>
                        <Button x:Name="BtnDeleteGrade" Content="Löschen"   Style="{StaticResource BtnDanger}"    IsEnabled="False" Click="BtnDeleteGrade_Click"/>
                    </StackPanel>
                </Border>
            </Grid>

        </Grid>
    </Grid>
</Window>
