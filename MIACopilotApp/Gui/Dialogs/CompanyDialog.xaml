<Window x:Class="MIACopilotApp.Gui.Dialogs.CompanyDialog"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="Firma hinzufügen"
        Height="340" Width="540"
        WindowStartupLocation="CenterOwner"
        ResizeMode="CanResize" ShowInTaskbar="False"
        FontFamily="Segoe UI" Background="White">

    <Window.Resources>
        <Style x:Key="FormLabel" TargetType="TextBlock">
            <Setter Property="FontSize"          Value="13"/>
            <Setter Property="Foreground"        Value="#374151"/>
            <Setter Property="VerticalAlignment" Value="Center"/>
            <Setter Property="Margin"            Value="0,0,0,12"/>
        </Style>
        <Style x:Key="FormBox" TargetType="TextBox">
            <Setter Property="FontSize"        Value="13"/>
            <Setter Property="Padding"         Value="10,8"/>
            <Setter Property="BorderBrush"     Value="#CBD5E0"/>
            <Setter Property="BorderThickness" Value="1"/>
            <Setter Property="Margin"          Value="0,0,0,12"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="TextBox">
                        <Border Background="White" BorderBrush="{TemplateBinding BorderBrush}"
                                BorderThickness="{TemplateBinding BorderThickness}" CornerRadius="5">
                            <ScrollViewer x:Name="PART_ContentHost" Margin="{TemplateBinding Padding}" VerticalAlignment="Center"/>
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsFocused" Value="True">
                                <Setter Property="BorderBrush" Value="#3D7EFF"/>
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>
        <Style x:Key="BtnPrimary" TargetType="Button">
            <Setter Property="Background" Value="#3D7EFF"/><Setter Property="Foreground" Value="White"/>
            <Setter Property="Padding" Value="20,8"/><Setter Property="BorderThickness" Value="0"/>
            <Setter Property="FontSize" Value="13"/><Setter Property="Cursor" Value="Hand"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <Border x:Name="Bd" Background="{TemplateBinding Background}" CornerRadius="6" Padding="{TemplateBinding Padding}">
                            <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"/>
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsMouseOver" Value="True"><Setter TargetName="Bd" Property="Background" Value="#2B6EEF"/></Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>
        <Style x:Key="BtnSecondary" TargetType="Button">
            <Setter Property="Background" Value="#EDF2F7"/><Setter Property="Foreground" Value="#374151"/>
            <Setter Property="Padding" Value="20,8"/><Setter Property="BorderThickness" Value="0"/>
            <Setter Property="FontSize" Value="13"/><Setter Property="Cursor" Value="Hand"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <Border x:Name="Bd" Background="{TemplateBinding Background}" CornerRadius="6" Padding="{TemplateBinding Padding}">
                            <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"/>
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsMouseOver" Value="True"><Setter TargetName="Bd" Property="Background" Value="#CBD5E0"/></Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>
    </Window.Resources>

    <Grid>
        <Grid.RowDefinitions>
            <RowDefinition Height="52"/>
            <RowDefinition Height="*"/>
            <RowDefinition Height="54"/>
        </Grid.RowDefinitions>

        <!-- Header -->
        <Border Grid.Row="0" Background="#1A2B4A">
            <TextBlock x:Name="TitleText" Text="Firma hinzufügen"
                       FontSize="15" FontWeight="SemiBold" Foreground="White"
                       Margin="20,0" VerticalAlignment="Center"/>
        </Border>

        <!-- Form -->
        <Grid Grid.Row="1" Margin="20,16,20,0">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="100"/>
                <ColumnDefinition Width="*"/>
            </Grid.ColumnDefinitions>
            <Grid.RowDefinitions>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="Auto"/>
            </Grid.RowDefinitions>

            <TextBlock Grid.Row="0" Grid.Column="0" Text="Name *"   Style="{StaticResource FormLabel}"/>
            <TextBox   Grid.Row="0" Grid.Column="1" x:Name="TbName" Style="{StaticResource FormBox}"/>

            <TextBlock Grid.Row="1" Grid.Column="0" Text="Adresse"     Style="{StaticResource FormLabel}"/>
            <TextBox   Grid.Row="1" Grid.Column="1" x:Name="TbAddress" Style="{StaticResource FormBox}"/>
        </Grid>

        <!-- Footer -->
        <Border Grid.Row="2" Background="#F7FAFC" BorderBrush="#E2E8F0" BorderThickness="0,1,0,0">
            <StackPanel Orientation="Horizontal" HorizontalAlignment="Right" Margin="16,0" VerticalAlignment="Center">
                <Button Content="Abbrechen" Style="{StaticResource BtnSecondary}" Click="BtnCancel_Click" Margin="0,0,8,0"/>
                <Button Content="Speichern" Style="{StaticResource BtnPrimary}"   Click="BtnSave_Click"/>
            </StackPanel>
        </Border>
    </Grid>
</Window>
